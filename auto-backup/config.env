# Public-safe auto-backup defaults.
# Run auto-backup/configure.sh to write local overrides for PR review/merge.
# Machine-local overrides can go in ignored auto-backup/config.local.env.

DOTFILES_AUTOBACKUP_MODE="device-only"
DOTFILES_AUTOBACKUP_REBASE="true"
DOTFILES_AUTOBACKUP_REVIEW="false"

# Reviewers are tried in order when PR review is enabled.
# OpenCode, Cursor, and Ollama are experimental selectors that fail closed.
DOTFILES_REVIEWERS="claude,codex,gemini"

# Model names are passed through to each CLI as best-effort strings.
DOTFILES_REVIEW_CLAUDE_MODELS="default,sonnet,haiku"
DOTFILES_REVIEW_CODEX_MODELS="default,gpt-5.4,gpt-5.4-mini"
DOTFILES_REVIEW_GEMINI_MODELS="default,gemini-3-flash-preview,flash"

# Experimental selectors exist but fail closed until tested for unattended merge.
# DOTFILES_REVIEW_OPENCODE_MODELS="default"
# DOTFILES_REVIEW_CURSOR_MODELS="default"
# DOTFILES_REVIEW_OLLAMA_MODELS="default"
